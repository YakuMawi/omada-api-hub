# ============================================================
# Omada API Hub — Configuration
# Copiez ce fichier en .env et adaptez les valeurs
# ============================================================

# Clé secrète Flask (OBLIGATOIRE — générez avec : python3 -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET_KEY=changez-moi-avec-une-valeur-aleatoire-longue

# Durée de session en secondes (défaut : 28800 = 8h)
SESSION_LIFETIME=28800
